@page "/"

<PageTitle>Liga Libre</PageTitle>

<h1>Liga Libre</h1>

<p>Sistema de gestion de torneos deportivos.</p>

<div class="row">
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Clubes</h5>
                <p class="card-text">Gestionar clubes: crear, editar y consultar informacion.</p>
                <a href="/clubs" class="btn btn-primary">Ver Clubes</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Torneos</h5>
                <p class="card-text">Crear torneos y ver sus detalles, partidos y posiciones.</p>
                <a href="/tournaments" class="btn btn-primary">Ver Torneos</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Login</h5>
                <p class="card-text">Iniciar sesion para acceder a funciones protegidas.</p>
                <a href="/login" class="btn btn-primary">Ingresar</a>
            </div>
        </div>
    </div>
</div>
