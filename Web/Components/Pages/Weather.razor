@using Web.Models
@using Web.Services
@inject IWeatherService WeatherService
@rendermode InteractiveServer

<div class="card">
    <div class="card-body">
        <h5 class="card-title">Clima en Buenos Aires</h5>
        @if (_loading)
        {
            <p class="card-text text-muted">Cargando clima...</p>
        }
        else if (_error is not null)
        {
            <p class="card-text text-danger">@_error</p>
        }
        else if (_weather is not null)
        {
            <p class="card-text">
                <span class="fs-3 fw-bold">@(_weather.TemperatureCelsius.ToString("F1"))°C</span>
                <br />
                <span class="text-muted">@_weather.Description</span>
            </p>
        }
    </div>
</div>

@code {
    private WeatherInfo? _weather;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _weather = await WeatherService.GetCurrentWeatherAsync("-34.6131", "-58.3772");
        }
        catch (Exception ex)
        {
            _error = $"No se pudo obtener el clima: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }
}