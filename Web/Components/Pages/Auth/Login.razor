@page "/login"
@using Web.Models
@using Web.Services
@inject AuthService AuthService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Login</PageTitle>

<h3>Iniciar Sesion</h3>

<div class="row">
    <div class="col-md-6">
        <EditForm Model="_request" OnValidSubmit="HandleLogin" FormName="Login">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label">Usuario</label>
                <InputText class="form-control" @bind-Value="_request.UserName" />
            </div>

            <div class="mb-3">
                <label class="form-label">Contrasena</label>
                <InputText class="form-control" type="password" @bind-Value="_request.Password" />
            </div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="alert alert-danger">@_error</div>
            }

            @if (_loginSuccess)
            {
                <div class="alert alert-success">
                    Login exitoso. Token expira: @_response!.Expiration.ToString("dd/MM/yyyy HH:mm")
                </div>
            }

            <button type="submit" class="btn btn-primary" disabled="@_submitting">
                @(_submitting ? "Ingresando..." : "Ingresar")
            </button>
        </EditForm>
    </div>
</div>

@code {
    private LoginRequest _request = new();
    private LoginResponse? _response;
    private string? _error;
    private bool _submitting;
    private bool _loginSuccess;

    private async Task HandleLogin()
    {
        _submitting = true;
        _error = null;
        _loginSuccess = false;

        try
        {
            _response = await AuthService.LoginAsync(_request);
            if (_response is not null)
            {
                _loginSuccess = true;
            }
            else
            {
                _error = "Credenciales invalidas";
            }
        }
        catch (Exception ex)
        {
            _error = $"Error: {ex.Message}";
        }
        finally
        {
            _submitting = false;
        }
    }
}
